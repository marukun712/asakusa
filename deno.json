{
	"tasks": {
		"docs": "deno run --allow-net --allow-read --allow-env docs/mod.ts",
		"relay": "deno run --allow-net --allow-env relay/mod.ts",
		"space": "deno run --allow-net --allow-env space/mod.ts",
		"voice-client": "deno run --allow-net --allow-read --allow-env voice-client/mod.ts",
		"tui": "deno run --allow-net --allow-ffi --allow-read --allow-env tui/mod.ts",
