{
	"tasks": {
		"build:cli": "deno compile --allow-net --allow-read --allow-write --allow-env --unstable-net --output dist/polka main.ts",
		"build:browser": "deno desktop --allow-net --allow-read --allow-env --output dist/polka-browser --include tools/browser/public tools/browser/mod.ts"
	},
	"workspace": [
		"types",
		"utils",
		"tools/voice-client",
		"server/pod",
		"server/relay",
		"server/space",
		"tools",
		"tools/browser"
	],
	"imports": {
		"@biomejs/biome": "npm:@biomejs/biome@^2.5.2",
		"@std/cli": "jsr:@std/cli@^1.0.32"
	}
}
