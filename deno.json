{
	"tasks": {
		"pod": "deno run --env-file --allow-net --allow-read --allow-env server/pod/mod.ts",
		"relay": "deno run --env-file --allow-net --allow-env --unstable-net server/relay/mod.ts",
		"space": "deno run --env-file --allow-net --allow-env --unstable-net server/space/mod.ts",
		"voice-client": "deno run --env-file --allow-net --allow-read --allow-env --unstable-net tools/voice-client/mod.ts",
		"setup": "deno run --env-file --allow-read --allow-write --allow-env tools/setup.ts",
		"builder": "deno run --env-file --allow-read --allow-write --allow-env tools/builder.ts",
		"browser": "deno run --env-file --allow-net --allow-read --allow-env tools/browser/mod.ts"
	},
	"workspace": [
		"types",
		"utils",
		"tools/voice-client",
		"server/pod",
		"server/relay",
		"server/space",
		"tools",
		"tools/browser"
	],
	"nodeModulesDir": "auto",
	"imports": {
		"@biomejs/biome": "npm:@biomejs/biome@^2.5.2"
	}
}
